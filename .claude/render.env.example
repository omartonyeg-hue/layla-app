# Copy to .claude/render.env (which is gitignored) and fill in.
# Generate the API key at https://dashboard.render.com/u/settings#api-keys
RENDER_API_KEY=rnd_REPLACE_ME

# Optional. If unset, scripts/render.sh auto-discovers by service name below.
# RENDER_SERVICE_ID=srv-xxxxxxxxxxxxxxxxxxxx

# Name used for auto-discovery (matches render.yaml's services[0].name).
RENDER_SERVICE_NAME=layla-backend
