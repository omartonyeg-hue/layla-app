// LAYLA — Phase 1 schema. Users, OTP challenges, profile, role.
// Later phases add Events, Parties, Valet, Community models.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled for runtime
  directUrl = env("DIRECT_URL")   // non-pooled for migrations
}

enum UserRole {
  GUEST   // I want to go out
  HOST    // I want to host private parties
  PRO     // Venue / DJ / promoter
}

enum City {
  CAIRO
  ALEXANDRIA
  SAHEL
  GOUNA
  SHARM
  HURGHADA
}

model User {
  id           String   @id @default(cuid())
  phone        String   @unique // E.164, e.g. +201221234567
  phoneVerified Boolean @default(false)
  role         UserRole?

  name         String?
  birthdate    DateTime? @db.Date
  city         City?
  vibes        String[] @default([])
  avatarColor  String?   // hex used in anon avatar stacks

  // Host reputation — denormalised for demo; real version derives from
  // completed parties + guest ratings.
  hostRating   Float?
  hostedCount  Int       @default(0)
  hostVerified Boolean   @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  otpChallenges OtpChallenge[]
  tickets       Ticket[]
  hostedParties Party[]         @relation("PartyHost")
  partyRequests PartyRequest[]
  posts         Post[]
  postLikes     PostLike[]
  postComments  PostComment[]
  stories       Story[]
  storyViews    StoryView[]
  rides         Ride[]
  subscription  Subscription?
  accounts      Account[]
}

// Instagram-style accounts. A User (auth entity) owns one personal
// Account (kind=USER) created at first sign-in. Users can additionally own
// Accounts of kind VENUE, DJ, or ORGANIZER — each with its own followers,
// handle, bio, privacy. Posts/Stories/Likes still reference User directly
// for now (migration churn isn't worth it for MVP); profile responses
// resolve User → personal Account for display. Future phases move post
// authorship onto Account.
enum AccountKind {
  USER       // personal profile, auto-created at signup
  VENUE      // club / bar / event space
  DJ         // performer / artist
  ORGANIZER  // promoter / collective / label
}

// USER accounts are always ACTIVE at creation. VENUE/DJ/ORGANIZER accounts
// start PENDING_REVIEW and are gated by admin approval before they can be
// followed, mentioned, or post. Rejected accounts are retained for appeal.
enum AccountStatus {
  ACTIVE
  PENDING_REVIEW
  REJECTED
}

model Account {
  id             String        @id @default(cuid())
  ownerUser      User          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  ownerUserId    String
  kind           AccountKind
  status         AccountStatus @default(ACTIVE)
  // Admin review metadata (null for USER kind; set when a venue/DJ/org
  // account is decided on). `reviewNote` surfaces the rejection reason to
  // the applicant in the app.
  reviewedAt     DateTime?
  reviewedById   String?       // User id of the admin; no FK to keep admin schema independent for now
  reviewNote     String?
  // Lowercase unique handle used as @mention key. 3-20 chars,
  // [a-z0-9_] — enforced in the route layer.
  handle         String        @unique
  displayName    String
  bio            String?       // 160-char max
  avatarUrl      String?       // Cloudinary URL (Phase 2)
  avatarColor    String?       // fallback when no avatarUrl
  isPrivate      Boolean       @default(false)
  isVerified     Boolean       @default(false)
  // Application info captured at creation for admin review (venues give
  // address/city; DJs/organizers give links + description).
  applicationCity     City?
  applicationAddress  String?
  applicationLinks    String[] @default([])
  applicationNote     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  followers      Follow[]      @relation("Followee")
  following      Follow[]      @relation("Follower")

  @@unique([ownerUserId, kind], map: "Account_owner_kind_unique_personal")
  @@index([ownerUserId])
  @@index([kind])
  @@index([status])
}
// Note: the @@unique on (ownerUserId, kind) prevents a User from having
// two personal accounts. VENUE/DJ/ORGANIZER accounts would need a
// different constraint — current version allows one of each kind per
// user, which is fine for MVP; remove if/when we want users to own
// multiple venues.

enum FollowStatus {
  APPROVED   // default; set immediately when target isPrivate=false
  PENDING    // waiting for followee approval when target isPrivate=true
}

model Follow {
  id          String       @id @default(cuid())
  follower    Account      @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followerId  String
  followee    Account      @relation("Followee", fields: [followeeId], references: [id], onDelete: Cascade)
  followeeId  String
  status      FollowStatus @default(APPROVED)
  createdAt   DateTime     @default(now())
  decidedAt   DateTime?

  @@unique([followerId, followeeId])
  @@index([followeeId, status])
  @@index([followerId, status])
}

// Phase 2 — Events.
// `gradient` is a token key (e.g. "sunset", "valet") that the mobile app maps
// to actual color stops via tokens.ts. Keeps visual decisions in code.
model Event {
  id          String   @id @default(cuid())
  name        String
  venue       String
  location    String?   // "Sidi Heneish · 120km west"
  description String
  startsAt    DateTime
  gradient    String    // "sunset" | "valet" | "night" | "community"
  lineup       String?
  tag         String?   // "HOT" | "NEW" | null
  featured    Boolean   @default(false)
  city        City?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tiers       EventTier[]
  tickets     Ticket[]
  posts       Post[]
}

model EventTier {
  id          String  @id @default(cuid())
  event       Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId     String
  name        String  // "Standard" | "VIP" | "Table (4 pax)"
  description String
  priceEgp    Int     // whole EGP — design shows "1,200 EGP"
  stockTotal  Int
  stockLeft   Int
  sortOrder   Int     @default(0)

  tickets     Ticket[]
}

model Ticket {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  event     Event    @relation(fields: [eventId], references: [id])
  eventId   String
  tier      EventTier @relation(fields: [tierId], references: [id])
  tierId    String
  orderRef  String   @unique // "#LYL-8AF-24"
  gate      String?  // "B · PRIORITY"
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Phase 3 — Parties.
// Address is hidden from the mobile API until the requester's PartyRequest is
// APPROVED. House rules are a simple string array; richer structure (per-rule
// acknowledgement) can arrive when the host-side UI lands.
enum PartyRequestStatus {
  PENDING
  APPROVED
  DECLINED
}

enum PartyTheme {
  ROOFTOP
  UNDERGROUND
  POOL
  BEACH
  LOFT
  HOUSE
}

model Party {
  id            String   @id @default(cuid())
  host          User     @relation("PartyHost", fields: [hostId], references: [id])
  hostId        String
  title         String
  theme         PartyTheme
  emoji         String   // single glyph shown on the card
  gradient      String   // "sunset" | "night" | "valet" | etc. (token key)
  neighborhood  String   // "Zamalek · Cairo"
  address       String   // full address, revealed only on approval
  doorDetail    String?  // "Building with blue door"
  startsAt      DateTime
  cap           Int      // max guests
  rules         String[] @default([])
  tag           String?  // "TONIGHT" | "STRICT DOOR" | "NEW HOST"
  city          City?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  requests      PartyRequest[]
}

// Phase 4 — Community.
// Single Post table keyed by `kind` so reviews, mood posts, and plain text
// posts share the same feed model. Only REVIEW posts care about stars/vibes.
// MOOD posts carry a gradient token key + emoji glyph and render as a coloured
// canvas card (real photo upload is deferred — no storage infra yet).
enum PostKind {
  REVIEW
  MOOD
  PHOTO
  TEXT
}

model Post {
  id             String   @id @default(cuid())
  author         User     @relation(fields: [authorId], references: [id])
  authorId       String
  kind           PostKind
  text           String?
  // REVIEW-only:
  stars          Int?     // 1–5
  vibes          String[] @default([])
  // MOOD (or any visual post) — gradient token key + centered emoji glyph.
  gradient       String?
  emoji          String?
  // Optional venue/event reference for reviews or mood posts tied to a venue.
  venueEvent     Event?   @relation(fields: [venueEventId], references: [id])
  venueEventId   String?
  createdAt      DateTime @default(now())

  likes          PostLike[]
  comments       PostComment[]

  @@index([createdAt])
  @@index([authorId, createdAt])
  @@index([venueEventId, createdAt])
}

model PostLike {
  id        String   @id @default(cuid())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId, createdAt])
}

model PostComment {
  id        String   @id @default(cuid())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  text      String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
  @@index([authorId, createdAt])
}

// Stories are ephemeral (default 24h) and render as a gradient canvas + emoji
// + optional caption — same "mood" visual language as MOOD posts.
model Story {
  id        String   @id @default(cuid())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  gradient  String
  emoji     String
  caption   String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  views     StoryView[]

  @@index([authorId, createdAt])
  @@index([expiresAt])
}

model StoryView {
  id        String   @id @default(cuid())
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  storyId   String
  viewer    User     @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  viewerId  String
  createdAt DateTime @default(now())

  @@unique([storyId, viewerId])
  @@index([viewerId, createdAt])
}

// Phase 5 — Valet.
// Drivers are vetted operators, not LAYLA users — they live in their own table
// with vehicle metadata. Rides reference both rider (User) and driver (Driver).
enum RideStatus {
  PENDING       // freshly created, no driver assigned
  MATCHING      // searching for a driver
  ASSIGNED      // driver assigned, on the way to pickup
  IN_PROGRESS   // driver has the rider, en route to dropoff
  COMPLETED
  CANCELED
}

model Driver {
  id             String   @id @default(cuid())
  name           String
  avatarColor    String?  // hex
  rating         Float
  trips          Int      @default(0)
  yearsActive    Int      @default(0)
  carMake        String   // "VW"
  carModel       String   // "Polo"
  carColor       String   // "White"
  plate          String   // "B 4291"
  transmission   String   // "AUTOMATIC"
  online         Boolean  @default(true)
  createdAt      DateTime @default(now())

  rides          Ride[]
}

model Ride {
  id             String   @id @default(cuid())
  rider          User     @relation(fields: [riderId], references: [id])
  riderId        String
  driver         Driver?  @relation(fields: [driverId], references: [id])
  driverId       String?
  pickupLabel    String   // "CJC Zamalek · 26th of July"
  dropoffLabel   String   // "Home · Maadi St. 9"
  distanceKm     Float    // 14.2
  etaMinutes     Int      // 22
  fareEgp        Int      // 220
  status         RideStatus @default(PENDING)
  createdAt      DateTime @default(now())
  assignedAt     DateTime?
  startedAt      DateTime?
  completedAt    DateTime?

  rating         RideRating?

  @@index([riderId, createdAt])
}

model RideRating {
  id        String   @id @default(cuid())
  ride      Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)
  rideId    String   @unique
  stars     Int      // 1-5
  tags      String[] @default([])
  tipEgp    Int      @default(0)
  comment   String?
  createdAt DateTime @default(now())
}

// Phase 6 — Pro / Scale.
// Subscription is a 1:1 with User (single active membership per user). Real
// payment integration (Stripe / Apple IAP) is deferred — `status: TRIALING`
// just means we mocked the purchase locally.
enum SubscriptionPlan {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  CANCELED
}

model Subscription {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id])
  userId          String   @unique
  plan            SubscriptionPlan
  status          SubscriptionStatus @default(TRIALING)
  priceEgp        Int      // monthly equivalent (799 annual / 899 monthly)
  startedAt       DateTime @default(now())
  trialEndsAt     DateTime?
  renewsAt        DateTime
  canceledAt      DateTime?

  @@index([userId])
}

// Pro-only "exclusive drops" — shown on the Dashboard preview + dedicated
// Drops screen.
enum DropTag {
  LIVE
  LIMITED
  EXCLUSIVE
}

model Drop {
  id           String   @id @default(cuid())
  name         String
  host         String   // "LAYLA Curated", "Partner · Gouna Marina", etc.
  neighborhood String
  emoji        String
  gradient     String   // token key
  startsAt     DateTime
  capacity     Int
  taken        Int      @default(0)
  tag          DropTag
  feeEgp       Int      // 0 means "FREE FOR PRO"
  createdAt    DateTime @default(now())

  @@index([startsAt])
}

model PartyRequest {
  id          String             @id @default(cuid())
  party       Party              @relation(fields: [partyId], references: [id], onDelete: Cascade)
  partyId     String
  requester   User               @relation(fields: [requesterId], references: [id])
  requesterId String
  status      PartyRequestStatus @default(PENDING)
  message     String?            // optional intro, 240 char cap in UI
  decidedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([partyId, requesterId])
  @@index([requesterId, status])
}

model OtpChallenge {
  id         String   @id @default(cuid())
  phone      String
  codeHash   String   // bcrypt hash of the 6-digit code
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id])
  userId     String?

  @@index([phone, createdAt])
}
